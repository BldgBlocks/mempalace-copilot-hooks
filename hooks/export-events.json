        "type": "command",
        "command": "$HOME/.venvs/mempalace-copilot/bin/python $HOME/.config/Code/User/copilot-hooks/export_chat_hook.py",
        "timeout": 15
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "$HOME/.venvs/mempalace-copilot/bin/python $HOME/.config/Code/User/copilot-hooks/export_chat_hook.py",
        "timeout": 15
      }
    ]
  }
